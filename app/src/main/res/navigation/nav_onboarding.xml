<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_onboarding"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.deliciachef.vista.onboarding.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_forgotPassword"
            app:destination="@id/forgotPasswordFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.deliciachef.vista.onboarding.RegisterFragment"
        android:label="Registro"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_personalInfo"
            app:destination="@id/personalInfoFragment" />
    </fragment>

    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.deliciachef.vista.onboarding.ForgotPasswordFragment"
        android:label="Recuperar"
        tools:layout="@layout/fragment_forgot_password" />

    <fragment
        android:id="@+id/personalInfoFragment"
        android:name="com.deliciachef.vista.onboarding.PersonalInfoFragment"
        android:label="Info Personal"
        tools:layout="@layout/fragment_personal_info" />

</navigation>